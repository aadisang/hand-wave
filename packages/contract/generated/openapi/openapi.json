{
  "openapi": "3.1.0",
  "info": {
    "title": "Hand Wave Inference API",
    "version": "0.0.0"
  },
  "tags": [],
  "paths": {
    "/v1/predict": {
      "post": {
        "operationId": "Routes_predict",
        "parameters": [],
        "responses": {
          "200": {
            "description": "The request has succeeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PredictOut"
                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PredictIn"
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Config": {
        "type": "object",
        "required": ["decode", "stream", "mp"],
        "properties": {
          "decode": {
            "$ref": "#/components/schemas/DecodeCfg"
          },
          "stream": {
            "$ref": "#/components/schemas/StreamCfg"
          },
          "mp": {
            "$ref": "#/components/schemas/MpCfg"
          }
        }
      },
      "DecodeCfg": {
        "type": "object",
        "required": ["window"],
        "properties": {
          "window": {
            "type": "integer",
            "format": "int32",
            "minimum": 8,
            "maximum": 512
          }
        }
      },
      "LandmarkFrame": {
        "type": "array",
        "items": {
          "type": "number",
          "format": "double"
        },
        "minItems": 162,
        "maxItems": 162
      },
      "MpCfg": {
        "type": "object",
        "required": ["smooth"],
        "properties": {
          "smooth": {
            "$ref": "#/components/schemas/SmoothSet"
          }
        }
      },
      "PredictIn": {
        "type": "object",
        "required": ["frames"],
        "properties": {
          "frames": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LandmarkFrame"
            },
            "minItems": 1,
            "maxItems": 512
          }
        }
      },
      "PredictOut": {
        "type": "object",
        "required": [
          "prediction",
          "alternatives",
          "spans",
          "greedy_text",
          "blank_ratio",
          "tail_blank_ratio",
          "tail_blank_frames",
          "partial_text",
          "stable_text"
        ],
        "properties": {
          "prediction": {
            "$ref": "#/components/schemas/Prediction"
          },
          "alternatives": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Prediction"
            }
          },
          "spans": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Span"
            }
          },
          "greedy_text": {
            "type": "string"
          },
          "blank_ratio": {
            "type": "number",
            "format": "double",
            "minimum": 0,
            "maximum": 1
          },
          "tail_blank_ratio": {
            "type": "number",
            "format": "double",
            "minimum": 0,
            "maximum": 1
          },
          "tail_blank_frames": {
            "type": "integer",
            "format": "int32"
          },
          "partial_text": {
            "type": "string"
          },
          "stable_text": {
            "type": "string"
          }
        }
      },
      "Prediction": {
        "type": "object",
        "required": ["label", "confidence"],
        "properties": {
          "label": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "format": "double",
            "minimum": 0,
            "maximum": 1
          },
          "logit_score": {
            "anyOf": [
              {
                "type": "number",
                "format": "double"
              },
              {
                "type": "null"
              }
            ]
          },
          "lm_score": {
            "anyOf": [
              {
                "type": "number",
                "format": "double"
              },
              {
                "type": "null"
              }
            ]
          },
          "raw_label": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "SmoothCfg": {
        "type": "object",
        "required": ["freq", "cutoff", "beta", "dCutoff"],
        "properties": {
          "freq": {
            "type": "number",
            "format": "double",
            "minimum": 0
          },
          "cutoff": {
            "type": "number",
            "format": "double",
            "minimum": 0
          },
          "beta": {
            "type": "number",
            "format": "double",
            "minimum": 0
          },
          "dCutoff": {
            "type": "number",
            "format": "double",
            "minimum": 0
          }
        }
      },
      "SmoothSet": {
        "type": "object",
        "required": ["hand", "pose"],
        "properties": {
          "hand": {
            "$ref": "#/components/schemas/SmoothCfg"
          },
          "pose": {
            "$ref": "#/components/schemas/SmoothCfg"
          }
        }
      },
      "Span": {
        "type": "object",
        "required": ["start_frame", "end_frame", "text"],
        "properties": {
          "start_frame": {
            "type": "integer",
            "format": "int32"
          },
          "end_frame": {
            "type": "integer",
            "format": "int32"
          },
          "text": {
            "type": "string"
          }
        }
      },
      "StreamCfg": {
        "type": "object",
        "required": [
          "fps",
          "min",
          "stride",
          "idle",
          "lost",
          "holdMs",
          "motion"
        ],
        "properties": {
          "fps": {
            "type": "integer",
            "format": "int32",
            "minimum": 1
          },
          "min": {
            "type": "integer",
            "format": "int32",
            "minimum": 1
          },
          "stride": {
            "type": "integer",
            "format": "int32",
            "minimum": 1
          },
          "idle": {
            "type": "integer",
            "format": "int32",
            "minimum": 1
          },
          "lost": {
            "type": "integer",
            "format": "int32",
            "minimum": 1
          },
          "holdMs": {
            "type": "integer",
            "format": "int32",
            "minimum": 1
          },
          "motion": {
            "type": "number",
            "format": "double",
            "minimum": 0
          }
        }
      }
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "variables": {}
    }
  ]
}
