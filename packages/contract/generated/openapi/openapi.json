{
  "openapi": "3.1.0",
  "info": {
    "title": "Hand Wave Inference API",
    "version": "0.0.0"
  },
  "tags": [],
  "paths": {
    "/v1/health": {
      "get": {
        "operationId": "Routes_health",
        "parameters": [],
        "responses": {
          "200": {
            "description": "The request has succeeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthOut"
                }
              }
            }
          }
        }
      }
    },
    "/v1/predict": {
      "post": {
        "operationId": "Routes_predict",
        "parameters": [],
        "responses": {
          "200": {
            "description": "The request has succeeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PredictOut"
                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PredictIn"
              }
            }
          }
        }
      }
    },
    "/v1/recognize": {
      "post": {
        "operationId": "Routes_recognize",
        "parameters": [],
        "responses": {
          "200": {
            "description": "The request has succeeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecognizeOut"
                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecognizeIn"
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Config": {
        "type": "object",
        "required": [
          "decode",
          "stream",
          "mp"
        ],
        "properties": {
          "decode": {
            "$ref": "#/components/schemas/DecodeCfg"
          },
          "stream": {
            "$ref": "#/components/schemas/StreamCfg"
          },
          "mp": {
            "$ref": "#/components/schemas/MpCfg"
          }
        }
      },
      "DecodeCfg": {
        "type": "object",
        "required": [
          "window"
        ],
        "properties": {
          "window": {
            "type": "integer",
            "format": "int32",
            "minimum": 8,
            "maximum": 512
          }
        }
      },
      "DecodeTrace": {
        "type": "object",
        "required": [
          "buffered_frames",
          "input_text",
          "display_text",
          "idle_frames",
          "motion",
          "latency_ms"
        ],
        "properties": {
          "buffered_frames": {
            "type": "integer",
            "format": "int32"
          },
          "input_text": {
            "type": "string"
          },
          "display_text": {
            "type": "string"
          },
          "idle_frames": {
            "type": "integer",
            "format": "int32"
          },
          "motion": {
            "type": "number",
            "format": "double"
          },
          "latency_ms": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "EndpointReason": {
        "type": "string",
        "enum": [
          "idle",
          "landmark-lost"
        ]
      },
      "FinalizeTrace": {
        "type": "object",
        "required": [
          "text",
          "confidence",
          "committed",
          "endpoint_reason",
          "segment_frames"
        ],
        "properties": {
          "text": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "format": "double"
          },
          "committed": {
            "type": "boolean"
          },
          "endpoint_reason": {
            "$ref": "#/components/schemas/EndpointReason"
          },
          "segment_frames": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "HealthOut": {
        "type": "object",
        "required": [
          "ok"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          }
        }
      },
      "LandmarkFrame": {
        "type": "array",
        "items": {
          "type": "number",
          "format": "double"
        },
        "minItems": 162,
        "maxItems": 162
      },
      "MpCfg": {
        "type": "object",
        "required": [
          "smooth"
        ],
        "properties": {
          "smooth": {
            "$ref": "#/components/schemas/SmoothSet"
          }
        }
      },
      "PredictIn": {
        "type": "object",
        "required": [
          "frames"
        ],
        "properties": {
          "frames": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LandmarkFrame"
            },
            "minItems": 1,
            "maxItems": 512
          }
        }
      },
      "PredictOut": {
        "type": "object",
        "required": [
          "prediction",
          "alternatives",
          "spans",
          "greedy_text",
          "blank_ratio",
          "tail_blank_ratio",
          "tail_blank_frames",
          "partial_text",
          "stable_text"
        ],
        "properties": {
          "prediction": {
            "$ref": "#/components/schemas/Prediction"
          },
          "alternatives": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Prediction"
            }
          },
          "spans": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Span"
            }
          },
          "greedy_text": {
            "type": "string"
          },
          "blank_ratio": {
            "type": "number",
            "format": "double",
            "minimum": 0,
            "maximum": 1
          },
          "tail_blank_ratio": {
            "type": "number",
            "format": "double",
            "minimum": 0,
            "maximum": 1
          },
          "tail_blank_frames": {
            "type": "integer",
            "format": "int32"
          },
          "partial_text": {
            "type": "string"
          },
          "stable_text": {
            "type": "string"
          }
        }
      },
      "Prediction": {
        "type": "object",
        "required": [
          "label",
          "confidence"
        ],
        "properties": {
          "label": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "format": "double",
            "minimum": 0,
            "maximum": 1
          },
          "logit_score": {
            "anyOf": [
              {
                "type": "number",
                "format": "double"
              },
              {
                "type": "null"
              }
            ]
          },
          "lm_score": {
            "anyOf": [
              {
                "type": "number",
                "format": "double"
              },
              {
                "type": "null"
              }
            ]
          },
          "raw_label": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "RecognitionContext": {
        "type": "object",
        "required": [
          "idle_frames",
          "missing_frames",
          "segment_frames",
          "motion"
        ],
        "properties": {
          "idle_frames": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "missing_frames": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "segment_frames": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "motion": {
            "type": "number",
            "format": "double",
            "minimum": 0
          },
          "endpoint_reason": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/EndpointReason"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "RecognitionCount": {
        "type": "object",
        "required": [
          "text",
          "count"
        ],
        "properties": {
          "text": {
            "type": "string"
          },
          "count": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "RecognitionScored": {
        "type": "object",
        "required": [
          "prediction",
          "score",
          "source",
          "model_agrees",
          "streak"
        ],
        "properties": {
          "prediction": {
            "$ref": "#/components/schemas/Prediction"
          },
          "score": {
            "type": "number",
            "format": "double"
          },
          "source": {
            "type": "string"
          },
          "lm_score": {
            "anyOf": [
              {
                "type": "number",
                "format": "double"
              },
              {
                "type": "null"
              }
            ]
          },
          "model_agrees": {
            "type": "boolean"
          },
          "streak": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "RecognitionState": {
        "type": "object",
        "required": [
          "selected_text",
          "selected_streak",
          "display_misses",
          "counts"
        ],
        "properties": {
          "display": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/RecognitionScored"
              },
              {
                "type": "null"
              }
            ]
          },
          "final_candidate": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/RecognitionScored"
              },
              {
                "type": "null"
              }
            ]
          },
          "selected_text": {
            "type": "string"
          },
          "selected_streak": {
            "type": "integer",
            "format": "int32"
          },
          "display_misses": {
            "type": "integer",
            "format": "int32"
          },
          "counts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RecognitionCount"
            }
          }
        }
      },
      "RecognitionTrace": {
        "type": "object",
        "properties": {
          "prediction": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/PredictOut"
              },
              {
                "type": "null"
              }
            ]
          },
          "decode": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/DecodeTrace"
              },
              {
                "type": "null"
              }
            ]
          },
          "finalize": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/FinalizeTrace"
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "RecognizeIn": {
        "type": "object",
        "required": [
          "context"
        ],
        "properties": {
          "frames": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LandmarkFrame"
            },
            "maxItems": 512
          },
          "state": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/RecognitionState"
              },
              {
                "type": "null"
              }
            ]
          },
          "context": {
            "$ref": "#/components/schemas/RecognitionContext"
          },
          "finalize": {
            "type": "boolean"
          }
        }
      },
      "RecognizeOut": {
        "type": "object",
        "required": [
          "state",
          "committed",
          "trace"
        ],
        "properties": {
          "state": {
            "$ref": "#/components/schemas/RecognitionState"
          },
          "display_prediction": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Prediction"
              },
              {
                "type": "null"
              }
            ]
          },
          "committed": {
            "type": "boolean"
          },
          "trace": {
            "$ref": "#/components/schemas/RecognitionTrace"
          }
        }
      },
      "SmoothCfg": {
        "type": "object",
        "required": [
          "freq",
          "cutoff",
          "beta",
          "dCutoff"
        ],
        "properties": {
          "freq": {
            "type": "number",
            "format": "double",
            "minimum": 0
          },
          "cutoff": {
            "type": "number",
            "format": "double",
            "minimum": 0
          },
          "beta": {
            "type": "number",
            "format": "double",
            "minimum": 0
          },
          "dCutoff": {
            "type": "number",
            "format": "double",
            "minimum": 0
          }
        }
      },
      "SmoothSet": {
        "type": "object",
        "required": [
          "hand",
          "pose"
        ],
        "properties": {
          "hand": {
            "$ref": "#/components/schemas/SmoothCfg"
          },
          "pose": {
            "$ref": "#/components/schemas/SmoothCfg"
          }
        }
      },
      "Span": {
        "type": "object",
        "required": [
          "start_frame",
          "end_frame",
          "text"
        ],
        "properties": {
          "start_frame": {
            "type": "integer",
            "format": "int32"
          },
          "end_frame": {
            "type": "integer",
            "format": "int32"
          },
          "text": {
            "type": "string"
          }
        }
      },
      "StreamCfg": {
        "type": "object",
        "required": [
          "fps",
          "min",
          "stride",
          "idle",
          "lost",
          "holdMs",
          "motion"
        ],
        "properties": {
          "fps": {
            "type": "integer",
            "format": "int32",
            "minimum": 1
          },
          "min": {
            "type": "integer",
            "format": "int32",
            "minimum": 1
          },
          "stride": {
            "type": "integer",
            "format": "int32",
            "minimum": 1
          },
          "idle": {
            "type": "integer",
            "format": "int32",
            "minimum": 1
          },
          "lost": {
            "type": "integer",
            "format": "int32",
            "minimum": 1
          },
          "holdMs": {
            "type": "integer",
            "format": "int32",
            "minimum": 1
          },
          "motion": {
            "type": "number",
            "format": "double",
            "minimum": 0
          }
        }
      }
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "variables": {}
    }
  ]
}
