{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hand-wave.local/schemas/Prediction.json",
  "type": "object",
  "properties": {
    "label": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "logit_score": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ]
    },
    "lm_score": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ]
    },
    "raw_label": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": ["label", "confidence"]
}
