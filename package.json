{
  "name": "hand-wave",
  "private": true,
  "scripts": {
    "build": "moon run :build",
    "check": "moon run :formatCheck :lint :typecheck :test",
    "check:affected": "moon run :formatCheck :lint :typecheck :test --affected",
    "dev": "moon run :dev",
    "fix": "moon run :format :lintFix",
    "format": "moon run :format",
    "format:check": "moon run :formatCheck",
    "lint": "moon run :lint",
    "lint:fix": "moon run :lintFix",
    "test": "moon run :test",
    "typecheck": "moon run :typecheck"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
